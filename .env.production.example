# LingTour production environment template.
# Copy to /root/LingTour/.env on the server and fill real secrets there.

DB_DATABASE=lingtour
DB_USERNAME=lingtour
DB_PASSWORD=change-me
JWT_SECRET=change-me

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://lingfengtranstour.cn/api/v1/auth/google/callback

NEXT_PUBLIC_API_URL=/api/v1
